YOUTUBE_API_KEY=your_youtube_api_key_here
REVALIDATE_SECRET=your_long_random_secret_here
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase project (server-side)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase project (client-side, public)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# YouTube Data API v3 key (필수 - 피드·라디오·요약 폴백용)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gemini API key (AI 3줄 요약용)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (요약 서버 캐싱용 - 선택)
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: server-to-server 재검증 호출 시 사용
REVALIDATE_SECRET=replace_with_a_long_random_secret

# 주인(운영자) 이메일: 이 이메일로 로그인한 사용자는 플랜 제한 없이 전 기능 사용
# OWNER_EMAIL=your_email@gmail.com

# Stripe (Pro 구독 결제)
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...  (Stripe Dashboard에서 Pro 월 구독 가격 ID)

# 사이트 URL (결제 성공/취소 리다이렉트, OAuth 콜백용)
# NEXT_PUBLIC_SITE_URL=https://your-domain.com